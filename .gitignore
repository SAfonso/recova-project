# =============================================================================
# Recova Project — .gitignore
# =============================================================================

# --- Secretos y Configuración ---
.env
.env.local
.env.*.local
*.secrets
secrets.json
*service-account*.json
*service_account*.json
google-sa*.json
google_sa*.json
# Ficheros OAuth2 generados por google_oauth_setup.py
token.json
token_*.json
client_secret*.json
credentials.json
# Certificados y claves privadas
*.pem
*.key
*.p12
*.pfx

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.coverage
.coverage.*
coverage.xml
htmlcov/
.mypy_cache/
.ruff_cache/
.venv/
venv/
ENV/
build/
dist/
*.egg-info/

# --- Logs del backend ---
backend/logs/
*.log
*.log.*

# --- Node.js ---
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# --- Frontend build ---
frontend/dist/
frontend/.env

# --- Docker ---
# Nota: Dockerfile, docker-compose.yml y .dockerignore SÍ deben estar en el repo

# --- SO y Editores ---
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.bak
*.orig

# --- Datos Locales ---
/data/*.csv
/data/*.json
!/data/.gitkeep
/backups/*
!/backups/.gitkeep

# --- Scripts locales de diagnóstico ---
backend/src/test.py
backend/src/getVeri.py
backend/scripts/compare_poster_renderers.py

# --- Scripts locales de seed/reset de datos (y sus tests) ---
backend/scripts/seed_full.py
backend/scripts/seed_conditional.py
backend/scripts/reset_data.py
backend/tests/scripts/test_seed_full.py
backend/tests/scripts/test_seed_conditional.py
backend/tests/scripts/test_reset_data.py

# --- Herramientas locales de desarrollo ---
.agents/
.claude/
.continue/
skills-lock.json
