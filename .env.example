# =============================================================================
# Recova Project — Variables de entorno (fuente única, raíz del repo)
# Copia este fichero como .env y rellena los valores
# =============================================================================

# --- Supabase ---
SUPABASE_URL=
SUPABASE_KEY=
SUPABASE_SERVICE_KEY=

# Conexión directa a PostgreSQL (Supabase → Settings → Database → URI)
# Usada por: setup_db.py, scoring_engine.py, bronze_to_silver_ingestion.py, backend/scripts/
DATABASE_URL=

# --- Backend Flask ---
WEBHOOK_API_KEY=

# URL pública de este backend (usada por Apps Script onFormSubmit)
# En local: http://localhost:5000
BACKEND_URL=

# URL pública del frontend (usada en links de validación de lineup)
# En local: http://localhost:5173
FRONTEND_URL=

# --- Google OAuth2 (Forms + Sheets) ---
# Obtener con: python backend/scripts/google_oauth_setup.py --client-secrets client_secret.json
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REFRESH_TOKEN=

# --- Telegram ---
TELEGRAM_BOT_USERNAME=

# --- n8n (solo si usas n8n local) ---
N8N_BACKEND_INGEST_URL=
N8N_BACKEND_SCORING_URL=
N8N_BACKEND_RENDER_URL=

# Gemini API (poster detector variante B)
GEMINI_API_KEY=tu_clave_de_google_ai_studio
