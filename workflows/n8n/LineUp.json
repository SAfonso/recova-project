    {
      "parameters": {
        "jsCode": "const items = $input.all();\n\n// Si no hay cómicos aprobados, devolvemos un error controlado o array vacío\nif (items.length === 0) return { error: \"No hay cómicos aprobados para esta fecha\" };\n\n// Mapeamos los cómicos al formato SDD §2.2\nconst lineup = items.map((item, index) => ({\n  order: index + 1,\n  name: item.json.nombre,\n  instagram: (item.json.instagram || \"\").replace('@', '').trim()\n}));\n\nreturn {\n  // Sacamos la fecha y el request_id del primer ítem (son comunes a todos)\n  request_id: items[0].json.request_id || \"7f3e82b0-1234-4a5b-8c9d-123456789abc\",\n  fecha_evento: items[0].json.fecha_evento,\n  lineup: lineup,\n  ahora_iso: new Date().toISOString()\n};"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        416,
        0
      ],
      "id": "06dacea3-e632-470c-afa8-951c71de132d",
