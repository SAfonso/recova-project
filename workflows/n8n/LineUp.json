        "url": "http://46.225.120.243:5050/render-lineup",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"schema_version\": \"1.0\",\n  \"request_id\": \"{{ $json.request_id || 'n8n-' + $now.format('X') }}\",\n  \"template\": {\n    \"template_id\": \"lineup_default_v1\",\n    \"width\": 1080,\n    \"height\": 1350,\n    \"format\": \"png\",\n    \"theme\": \"default\",\n    \"quality\": 100\n  },\n  \"storage\": {\n    \"bucket\": \"posters\",\n    \"path_prefix\": \"{{ $now.format('YYYY-MM') }}\"\n  },\n  \"render\": {\n    \"format\": \"png\",\n    \"quality\": 100,\n    \"scale\": 1,\n    \"timeout_ms\": 30000,\n    \"use_cache\": false,\n    \"include_mcp\": true\n  },\n  \"metadata\": {\n  \"author\": \"n8n_curator\",\n  \"project\": \"RECOVA\",\n  \"initiated_at\": \"{{ $json.ahora_iso }}\", \n  \"trace_id\": \"n8n_{{ $execution.id }}\",\n  \"version\": \"0.5.30\"\n  },\n  \"event\": {\n    \"date\": \"{{ $json.fecha_evento }}\",\n    \"title\": \"LA RECOVA OPEN MIC\",\n    \"timezone\": \"Europe/Madrid\"\n  },\n  \"lineup\": {{ JSON.stringify($json.lineup) }}\n}\n",
