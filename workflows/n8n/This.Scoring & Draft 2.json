      "id": "57951fc7-5ee4-46ba-bd57-3f1a19047ba7",
      "type": "n8n-nodes-base.if",
      "typeVersion": 1,
      "position": [
        784,
        -112
      ],
      "name": "IF (tiene link?)"
    },
    {
      "parameters": {
        "jsCode": "// Formatea el mensaje de Telegram con lineup + link\nconst prep = $input.item.json;\nconst lineup = prep.lineup || [];\n\nconst lineupText = lineup.map((c, i) => {\n  const ig = c.instagram ? ` (@${c.instagram})` : '';\n  return `${i + 1}. ${c.nombre}${ig}`;\n}).join('\\n');\n\nlet fechaDisplay = prep.fecha_evento || '';\ntry {\n  fechaDisplay = new Date(prep.fecha_evento + 'T12:00:00').toLocaleDateString('es-ES', {\n    weekday: 'long', day: 'numeric', month: 'long'\n  });\n} catch(e) {}\n\nconst nombreShow = $('Code (flatten)').item.json.open_mic_nombre || 'tu show';\n\nreturn [{\n  json: {\n    telegram_user_id: $('Code (flatten)').item.json.telegram_user_id,\n    message_text: `Lineup para ${nombreShow} (${fechaDisplay}):\\n\\n${lineupText}\\n\\nValida aqui antes de que empiece el show:\\n${prep.validate_url}`,\n  }\n}];"
      },
