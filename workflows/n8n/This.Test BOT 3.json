          "name": "Telegram account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const INJECTION_RE = /(?:ignora|olvida|descarta|omite)\\s+(?:las\\s+)?instrucciones|(?:ignore|forget|disregard|override)\\s+(?:all\\s+)?(?:previous\\s+)?instructions?|(?:ahora\\s+eres|act[uú]a\\s+como|you\\s+are\\s+now|act\\s+as|pretend\\s+to\\s+be)|(?:system\\s+prompt|reveal\\s+your|muestra\\s+tu\\s+prompt)|<\\/?\\s*system\\s*>|\\[\\/?\\s*INST\\s*\\]|<<\\s*SYS\\s*>>/i;                                                                     \n                                                            \nconst INVISIBLE_RE = /[\\u200b-\\u200f\\u2060-\\u2064\\ufeff\\u202a-\\u202e\\u2066-\\u2069\\x00-\\x08\\x0b\\x0c\\x0e-\\x1f]/g;\nconst MAX_LEN = 500;                                                                                    \n                                                            \nconst items = $input.all();\n\nfor (const item of items) {\n  let text = item.json.message?.text || '';\n                                                                                                          \n    // 1. Strip invisibles\n  text = text.replace(INVISIBLE_RE, '');                                                                \n                                                            \n    // 2. Truncar\n  text = text.slice(0, MAX_LEN);\n\n    // 3. Detectar injection                                                                              \n  if (INJECTION_RE.test(text)) {\n    item.json.blocked = true;                                                                           \n    item.json.message.text = '[MENSAJE BLOQUEADO POR SEGURIDAD]';\n  } else {                                                                                              \n    item.json.message.text = text;\n  }                                                                                                     \n} \n\n\n\n\n\n\n\n\n\n"
      },
