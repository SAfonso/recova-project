      "parameters": {
        "jsCode": "const rawText = $json.text || $json.output || $json.message.content;\nconst cleanText = rawText.replace(/```json|```/g, \"\").trim();\nconst listaComicos = JSON.parse(cleanText);\nreturn listaComicos;"
