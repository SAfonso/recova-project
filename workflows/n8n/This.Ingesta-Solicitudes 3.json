    {
      "parameters": {
        "promptType": "define",
        "text": "=\"Eres un clasificador de género masivo. Recibirás una lista de comediantes.\\n\\nTu tarea: Clasifica el género de cada uno basándote en su nombre e instagram.\\nReglas: Responde ÚNICAMENTE con un array de objetos JSON con este formato: [{\\\"id\\\": \\\"...\\\", \\\"genero\\\": \\\"m|f|nb|unknown\\\"}].\\n\\nLista de entrada:\" + {{ JSON.stringify($json.data) }}",
        "batching": {}
