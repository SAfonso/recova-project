    {
      "parameters": {
        "jsCode": "// Sanitize Fields — strip control chars, truncar, detectar injection patterns\nconst INJECTION_RE = /(?:ignora|olvida|descarta|ignore|forget|disregard)\\s+(?:las?\\s+)?(?:all\\s+)?(?:previous\\s+)?instruc/i;                                                          \nconst MAX_LEN = 80;\n  \nfor (const item of $input.all()) {\n  // Strip Unicode invisibles y control chars\n  for (const key of ['nombre', 'instagram']) {\n    let val = (item.json[key] || '')\n      .replace(/[\\u200b-\\u200f\\u2060-\\u2064\\ufeff\\u202a-\\u202e\\u2066-\\u2069]/g, '')\n      .replace(/[\\x00-\\x08\\x0b\\x0c\\x0e-\\x1f]/g, '')\n      .slice(0, MAX_LEN);\n\n    if (INJECTION_RE.test(val)) {\n      val = '[REDACTED]';                                 \n    }\n    item.json[key] = val;                                 \n  }\n}\n\nreturn $input.all(); "
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
